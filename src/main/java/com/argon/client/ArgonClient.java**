package com.argon.client;

import net.fabricmc.api.ClientModInitializer;
import com.argon.client.module.ModuleManager;
import com.argon.client.gui.ClickGui;
import com.argon.client.event.TickListener;

public class ArgonClient implements ClientModInitializer {
    @Override
    public void onInitializeClient() {
        ModuleManager.getInstance().loadModules();      // register modules
        ClickGui.init();                                 // placeholder GUI
        // Register a global tick callback that forwards to any Tickable module
        TickListener.INSTANCE.register(() -> {
            ModuleManager.getInstance().getModules().stream()
                    .filter(m -> m instanceof com.argon.client.module.Tickable)
                    .forEach(m -> ((com.argon.client.module.Tickable) m).onTick());
        });
    }
}