package com.argon.client.mixin;

import com.argon.client.module.impl.combat.Reach;
import com.argon.client.module.impl.combat.Velocity;
import net.minecraft.entity.player.PlayerEntity;
import net.minecraft.network.packet.s2c.play.EntityVelocityUpdateS2CPacket;
import org.spongepowered.asm.mixin.Mixin;
import org.spongepowered.asm.mixin.Shadow;
import org.spongepowered.asm.mixin.injection.At;
import org.spongepowered.asm.mixin.injection.Inject;
import org.spongepowered.asm.mixin.injection.callback.CallbackInfo;

/**
 * Handles the Velocity and Reach modules.
 */
@Mixin(PlayerEntity.class)
public abstract class PlayerEntityMixin {

    @Shadow public abstract double getAttributeValue(net.minecraft.registry.entry.RegistryEntry.Reference<?> entry);

    /** Cancel knock‑back packets when Velocity is active. */
    @Inject(method = "onVelocityUpdate", at = @At("HEAD"), cancellable = true)
    private void onVelocityPacket(EntityVelocityUpdateS2CPacket packet, CallbackInfo ci) {
        if (Velocity.isActive()) {
            ci.cancel(); // No knock‑back
        }
    }

    /** Extend attack reach when the Reach module is enabled. */
    @Inject(method = "isInRange", at = @At("HEAD"), cancellable = true)
    private void modifyReach(double distance, CallbackInfo ci) {
        double reach = Reach.getReachDistance();
        if (distance <= reach) {
            ci.cancel(); // Allow attack
        }
    }
}