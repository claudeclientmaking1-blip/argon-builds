package com.argon.client.event;

import net.fabricmc.api.ClientModInitializer;
import net.fabricmc.fabric.api.client.event.lifecycle.v1.ClientTickEvents;

import java.util.ArrayList;
import java.util.List;

/**
 * Simple global tick dispatcher. Modules register a Runnable here.
 */
public class TickListener implements ClientModInitializer {
    public static final TickListener INSTANCE = new TickListener();

    private final List<Runnable> callbacks = new ArrayList<>();

    public void register(Runnable r) {
        callbacks.add(r);
    }

    @Override
    public void onInitializeClient() {
        ClientTickEvents.END_CLIENT_TICK.register(client -> callbacks.forEach(Runnable::run));
    }
}