package com.argon.client.module.impl.combat;

import com.argon.client.module.Module;
import net.minecraft.client.MinecraftClient;

/**
 * Extends the player's attack reach while enabled.
 * The actual reach check is performed in {@link com.argon.client.mixin.PlayerEntityMixin}.
 */
public class Reach extends Module {
    public Reach() {
        super("Reach");
    }

    @Override
    public void onEnable() {}

    @Override
    public void onDisable() {}

    /** Returns the current reach distance. */
    public static double getReachDistance() {
        boolean enabled = ModuleManager.getInstance().getModules().stream()
                .filter(m -> m instanceof Reach)
                .map(m -> (Reach) m)
                .findFirst()
                .map(Reach::isEnabled)
                .orElse(false);
        return enabled ? 6.0 : 4.5; // 6 blocks when enabled, default otherwise
    }
}