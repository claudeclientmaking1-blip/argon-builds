package com.argon.client.module.impl.combat;

import com.argon.client.module.Module;
import com.argon.client.mixin.PlayerEntityMixin;
import net.minecraft.client.network.ClientPlayerEntity;
import net.minecraft.entity.LivingEntity;
import net.minecraft.network.packet.s2c.play.EntityVelocityUpdateS2CPacket;

public class Velocity extends Module {
    public Velocity() {
        super("Velocity");
    }

    @Override
    public void onEnable() {
        // Mixins will automatically cancel the packet when this module is enabled.
    }

    @Override
    public void onDisable() {
        // No cleanup needed.
    }

    /** Helper used by the mixin to check if the module is active. */
    public static boolean isActive() {
        return ModuleManager.getInstance().getModules().stream()
                .filter(m -> m instanceof Velocity)
                .map(m -> (Velocity) m)
                .findFirst()
                .map(Velocity::isEnabled)
                .orElse(false);
    }
}